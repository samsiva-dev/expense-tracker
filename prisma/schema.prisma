// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  expenses      Expense[]
  loans         Loan[]
  subscriptions Subscription[]
  notifications Notification[]
  incomes       Income[]
  settings      UserSettings?
  budgets       Budget[]
  emis          Emi[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Expense {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  category    String
  date        DateTime
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([date])
}

model Loan {
  id           String    @id @default(cuid())
  lenderName   String
  amount       Float
  borrowedDate DateTime
  dueDate      DateTime?
  status       String    @default("PENDING")
  notes        String?
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

model Subscription {
  id              String   @id @default(cuid())
  name            String
  amount          Float
  billingCycle    String   @default("MONTHLY")
  nextDueDate     DateTime
  category        String
  description     String?
  isActive        Boolean  @default(true)
  trackInExpenses Boolean  @default(true)
  minimumCharge   Float?
  lastPaidDate    DateTime?
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([nextDueDate])
}

model Budget {
  id        String   @id @default(cuid())
  category  String
  amount    Float
  month     Int
  year      Int
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, category, month, year])
  @@index([userId])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  message     String
  isRead      Boolean  @default(false)
  relatedId   String?
  relatedType String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
}

model Income {
  id               String   @id @default(cuid())
  amount           Float
  currency         String   @default("INR")
  amountInr        Float
  exchangeRate     Float    @default(1)
  type             String   @default("SALARY")
  date             DateTime
  description      String?
  remittanceAmount Float?
  remittanceNote   String?
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([date])
}

model UserSettings {
  id           String   @id @default(cuid())
  userId       String   @unique
  baseCurrency String   @default("INR")
  earnCurrency String   @default("INR")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Emi {
  id           String   @id @default(cuid())
  loanName     String
  lenderName   String
  loanType     String   @default("PERSONAL")
  principal    Float
  interestRate Float
  tenureMonths Int
  startDate    DateTime
  emiAmount    Float
  paidMonths   Int      @default(0)
  status       String   @default("ACTIVE")
  notes        String?
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([status])
}
